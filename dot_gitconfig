[init]
	defaultBranch = main
[pull]
	rebase = false

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	syntax-theme = TwoDark
	line-numbers = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default
